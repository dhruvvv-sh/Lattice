# Python bytecode: generated automatically when modules are imported.
__pycache__/
*.py[cod]
*$py.class

# Virtual environments: local dependency installs should not be committed.
.venv/
venv/
env/
ENV/

# Environment files: local secrets and database URLs belong outside git.
.env
.envrc
.env.local
.env.*.local

# Test and coverage output: reproducible local artifacts from pytest/coverage.
.pytest_cache/
.coverage
.coverage.*
htmlcov/
cover/

# Type checker and linter caches: local analysis output.
.mypy_cache/
.pyre/
.pytype/
.ruff_cache/

# Build and packaging output: generated by Python packaging tools.
build/
dist/
*.egg-info/
*.egg
MANIFEST

# Local databases: developer-only metadata stores.
*.db
*.sqlite
*.sqlite3

# Runtime logs: generated by apps, servers, or local debugging.
*.log

# Local object-storage outputs: files produced by upload/recovery experiments.
storage/bucket_*/
storage/disk*/bucket_*/
storage/disk*/object_*.part*
original_part2.bin
recovered_part2.bin
restored.pdf

# Editor scratch files: temporary files created by local tooling.
tempCodeRunnerFile.py
notes
